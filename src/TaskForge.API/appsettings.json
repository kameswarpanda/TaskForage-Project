{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=(local);Database=TaskForgeDB;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true;Connection Timeout=30;Max Pool Size=100;"
  },
  "JwtSettings": {
    "SecretKey": "TaskForge_SuperSecret_Key_2024_Must_Be_At_Least_32_Characters!",
    "Issuer": "TaskForge.API",
    "Audience": "TaskForge.Client",
    "ExpiryMinutes": 60
  },
  "AllowedHosts": "*"
}